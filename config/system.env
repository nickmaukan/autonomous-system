# Configuración del Sistema Autonomo v2.0

## API Keys

# Obtiene gratis en:
# - Alpha Vantage: https://www.alphavantage.co/support/#api-key
# - NewsAPI: https://newsapi.org/register
# - Brave: https://brave.com/search/api/

ALPHA_VANTAGE_KEY=tu_alpha_vantage_key_aqui
NEWS_API_KEY=tu_news_api_key_aqui
BRAVE_API_KEY=tu_brave_api_key_aqui

## Configuración del Sistema

# Intervalo del ciclo autónomo (segundos)
CYCLE_INTERVAL=300

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Habilitar notificaciones
NOTIFICATION_ENABLED=true

# Canal de notificación (telegram, whatsapp, email)
NOTIFICATION_CHANNEL=telegram

# Puerto del API local
API_PORT=3003

## Límites

# Máximo de decisiones a guardar en historial
MAX_DECISION_HISTORY=100

# Máximo de ideas en pipeline
MAX_IDEAS=50

# Timeout para llamadas a APIs (segundos)
API_TIMEOUT=30
